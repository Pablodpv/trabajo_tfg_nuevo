<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8">
        <title>{% block title %}HardWave - Tienda de Hardware{% endblock %}</title>
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>⚫️</text><text y=%221.3em%22 x=%220.2em%22 font-size=%2276%22 fill=%22%23fff%22>sf</text></svg>">
        
        {# Bootstrap 5 CSS #}
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
        
        <style>
            body { background-color: #f4f7f6; }
            .navbar-brand { font-weight: 800; letter-spacing: 1px; }
            .nav-link { font-weight: 500; }
            .main-content { padding-top: 2rem; }
        </style>

        {% block stylesheets %}{% endblock %}

       
        {% set frankenphpHotReload = app.request.server.get('FRANKENPHP_HOT_RELOAD') %}
        {% if frankenphpHotReload %}
            <meta name="frankenphp-hot-reload:url" content="{{ frankenphpHotReload }}">
            <script src="https://cdn.jsdelivr.net/npm/idiomorph"></script>
            <script src="https://cdn.jsdelivr.net/npm/frankenphp-hot-reload/+esm" type="module"></script>
        {% endif %}
    </head>
    <body>

        {# BARRA DE NAVEGACIÓN: Solo se muestra si el usuario está logueado #}
        {% if app.session.get('user_logged') %}
        <nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow">
            <div class="container">
                <a class="navbar-brand text-info" href="{{ path('app_hardware') }}">HARDWAVE</a>
                
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav me-auto">
                        <li class="nav-item">
                            <a class="nav-link" href="{{ path('app_hardware') }}">Hardware</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="{{ path('app_perifericos') }}">Periféricos</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="#">PCs Montados</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-warning" href="#">Ofertas</a>
                        </li>
                    </ul>

<a class="nav-link position-relative" href="{{ path('app_carrito') }}">
    🛒 Carrito
  
    {% if app.session.get('carrito')|length > 0 %}
        <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger">
            {{ app.session.get('carrito')|length }}
        </span>
    {% endif %}
</a>
                    
                    <div class="d-flex align-items-center">
                        <span class="text-light me-3 small">{{ app.session.get('user_email') }}</span>
                        <a href="{{ path('app_logout') }}" class="btn btn-outline-danger btn-sm fw-bold">Cerrar Sesión</a>
                    </div>
                </div>
            </div>
        </nav>
        {% endif %}

        {# CONTENEDOR PRINCIPAL #}
        <div class="container main-content">
            {% block body %}{% endblock %}
        </div>

        {# Bootstrap JS #}
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
        {% block javascripts %}{% endblock %}
    </body>
</html>
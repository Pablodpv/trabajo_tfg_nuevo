{% extends 'base.html.twig' %}

{% block title %}Mi Carrito - HardWave{% endblock %}

{% block body %}
<div class="container mt-5">
    <h2 class="fw-bold mb-4">🛒 Tu selección de Hardware</h2>
    
    {% if carrito|length > 0 %}
        <div class="card shadow-sm border-0">
            <div class="card-body p-0">
                <table class="table table-hover mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th class="ps-4">Producto</th>
                            <th>Precio</th>
                            <th class="text-end pe-4">Hora añadido</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% set total = 0 %}
                        {% for item in carrito %}
                            <tr>
                                <td class="ps-4"><strong>{{ item.nombre }}</strong></td>
                                <td>{{ item.precio }}€</td>
                                <td class="text-end pe-4 text-muted small">{{ item.fecha|date('H:i:s') }}</td>
                            </tr>
                            {% set total = total + item.precio %}
                        {% endfor %}
                        <tr class="table-info">
                            <td class="text-end fw-bold h5">Total a pagar:</td>
                            <td colspan="2" class="fw-bold h5 text-primary ps-3">{{ total }}€</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>

        <div class="d-flex justify-content-between mt-4">
            <a href="{{ path('app_carrito_vaciar') }}" class="btn btn-outline-danger">Vaciar Carrito</a>
            <button class="btn btn-success btn-lg px-5 fw-bold">Proceder al pago</button>
        </div>
    {% else %}
        <div class="text-center py-5">
            <p class="fs-4 text-muted">Parece que tu carrito está vacío.</p>
            <a href="{{ path('app_hardware') }}" class="btn btn-primary">Volver al catálogo</a>
        </div>
    {% endif %}
</div>
{% endblock %}
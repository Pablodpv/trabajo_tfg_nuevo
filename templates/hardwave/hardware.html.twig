{% extends 'base.html.twig' %}

{% block body %}

    <div class="p-5 mb-4 bg-dark text-white rounded-3 shadow mt-4">
        <div class="container-fluid py-5">
            <h1 class="display-5 fw-bold">Catálogo de Hardware</h1>
            <p class="col-md-8 fs-4">Explora nuestra selección premium de componentes de última generación.</p>
        </div>
    </div>

    <h3 class="mb-4 fw-bold border-bottom pb-2">Componentes Disponibles</h3>
    
    <div class="row">
        {% for p in products %}
            <div class="col-md-4 col-lg-3 mb-4">
                <div class="card h-100 shadow-sm border-0 position-relative">
                    <span class="position-absolute top-0 end-0 badge rounded-pill bg-success m-2">En Stock</span>
                    <img src="{{ p.img }}" class="card-img-top" style="height: 180px; object-fit: cover;">
                    
                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title fw-bold">{{ p.name }}</h5>
                        <p class="card-text text-muted small flex-grow-1">{{ p.desc }}</p>
                        
                        <div class="mt-3">
                            <div class="d-flex justify-content-between align-items-center">
                                <span class="h5 mb-0 text-primary fw-bold">{{ p.price }}€</span>
                                

                                <a href="{{ path('app_carrito_add', {'nombre': p.name, 'precio': p.price}) }}" 
                                   class="btn btn-primary btn-sm px-3">
                                   Comprar
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        {% else %}
            <div class="col-12 text-center py-5">
                <p class="text-muted">No hay productos disponibles en este momento.</p>
            </div>
        {% endfor %}
    </div>
{% endblock %}
{% extends 'base.html.twig' %}

{% block title %}Registro - HardWave{% endblock %}

{% block body %}
<div class="row justify-content-center mt-5">
    <div class="col-md-6">
        <div class="card shadow border-0">
            <div class="card-body p-5">
                <h2 class="text-center mb-4 fw-bold text-primary">HARDWAVE</h2>
                <h4 class="text-center mb-4">Crear Cuenta</h4>

                {{ form_start(registrationForm) }}
                    <div class="mb-3">
                        {{ form_label(registrationForm.email, 'Correo Electrónico', {'label_attr': {'class': 'form-label'}}) }}
                        {{ form_widget(registrationForm.email, {'attr': {'class': 'form-control', 'placeholder': 'ejemplo@correo.com'}}) }}
                        {{ form_errors(registrationForm.email) }}
                    </div>

                    <div class="mb-3">
                        {{ form_label(registrationForm.plainPassword, 'Contraseña', {'label_attr': {'class': 'form-label'}}) }}
                        {{ form_widget(registrationForm.plainPassword, {'attr': {'class': 'form-control'}}) }}
                        {{ form_errors(registrationForm.plainPassword) }}
                    </div>

                    <button type="submit" class="btn btn-primary w-100 btn-lg shadow-sm mt-3">Registrarse</button>
                {{ form_end(registrationForm) }}

                <div class="text-center mt-4">
                    <span class="text-muted">¿Ya tienes cuenta?</span> 
                    <a href="{{ path('app_login') }}" class="text-decoration-none fw-bold">Inicia sesión</a>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}